# Neon Postgres — fourni par l'intégration Vercel ↔ Neon
# Pour récupérer les valeurs en local: `vercel env pull .env.local --environment=production`
NEON_DB_DATABASE_URL=
NEON_DB_DATABASE_URL_UNPOOLED=

# Auth (générer AUTH_SECRET avec: openssl rand -base64 32)
AUTH_SECRET=
AUTH_PASSWORD=

# Anthropic (Phase 2+)
ANTHROPIC_API_KEY=
